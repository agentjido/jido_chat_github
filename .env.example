# Copy this file to `.env` and fill in real values.
# `test/test_helper.exs` loads `.env` with Dotenvy before tests run.

# Set true to enable tests tagged `:live`.
RUN_LIVE_GITHUB_TESTS=false

# Fine-grained PAT or GitHub App installation token with Issues: write.
GITHUB_TOKEN=

# Shared secret configured on the GitHub webhook.
GITHUB_WEBHOOK_SECRET=

# Format: owner/repo#issue_number
# Use a disposable issue because the live test creates, edits, and deletes a comment.
GITHUB_TEST_ISSUE=agentjido/some-repo#1
